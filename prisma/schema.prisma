generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(TENANT)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  // acesso do profissional: User role BARBER ligado 1:1 a um Barber
  barberId  String?  @unique
  barber    Barber?  @relation(fields: [barberId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pushSubscriptions PushSubscription[]

  @@index([tenantId])
}

enum Role {
  MASTER
  TENANT
  BARBER
}

// Inscricao de Web Push (notificacao). Uma por dispositivo/navegador do usuario.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  phone        String?
  email        String?
  address      Json?
  logo         String?
  colorPrimary String       @default("#18181B")
  colorAccent  String       @default("#D4A853")
  openingHours Json?
  timezone     String       @default("America/Sao_Paulo")
  leadTimeMin  Int          @default(30)
  // pagamento — Asaas por barbearia (apiKey cifrada; wallet da agencia e env)
  asaasApiKey       String?
  asaasSandbox      Boolean  @default(false)
  asaasWebhookToken String?  // gerado forte (randomBytes) ao ativar pagamento; ver salvarConfigPagamento
  // politica de agendamento: exige pagar pra marcar, deixa opcional, ou so agenda.
  // So tem efeito quando ha apiKey; sem Asaas a barbearia e sempre "so agendar".
  bookingMode    BookingMode @default(PAYMENT_REQUIRED)
  // sistema de incentivo: desconto pra quem paga adiantado (tag % off nos botoes).
  // O desconto incide sobre o TOTAL; no sinal, paga 50% do total ja descontado.
  incentivoAtivo  Boolean @default(false)
  descontoSinalPct Int    @default(0) // 0..90
  descontoTotalPct Int    @default(0) // 0..90
  // avaliacao no Google (mecanismo da pagina de obrigado)
  googleReviewUrl   String?
  status       TenantStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users     User[]
  services  Service[]
  barbers   Barber[]
  bookings  Booking[]
  clients   Client[]
  units     Unit[]
  products  Product[]
}

// Produto de balcao vendido como order bump no checkout ("Aproveite tambem").
model Product {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  imageUrl    String? // opcional; transcodar p/ WebP (diretriz de assets leves)
  active      Boolean  @default(true)
  isOrderBump Boolean  @default(true) // aparece no bloco "Aproveite tambem"
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  bookingItems BookingItem[]

  @@index([tenantId])
}

enum TenantStatus {
  ONBOARDING
  ACTIVE
  PAUSED
  CANCELLED
}

model Unit {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  address   Json?
  phone     String?
  active    Boolean @default(true)

  barberUnits      BarberUnit[]
  bookings         Booking[]
  workShifts       WorkShift[]
  unavailabilities Unavailability[]

  @@unique([tenantId, slug])
}

model Service {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  category    ServiceCategory
  description String?
  price       Float
  durationMin Int
  active      Boolean         @default(true)
  sortOrder   Int             @default(0)

  bookings Booking[]

  @@index([tenantId])
}

enum ServiceCategory {
  HAIR
  BEARD
  CHEMISTRY
  AESTHETICS
  COMBO
  TREATMENT
}

model Barber {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  nickname     String?
  photoUrl     String?
  whatsapp     String?  // WhatsApp do barbeiro p/ notificacao de agendamento (Fase 2 / Evolution)
  notifyEmail  String?  // email de notificacao do barbeiro (separado do login)
  commissionPct Float  @default(50)
  active       Boolean @default(true)

  units            BarberUnit[]
  bookings         Booking[]
  blocks           BarberBlock[]
  workShifts       WorkShift[]
  unavailabilities Unavailability[]
  user             User?

  @@index([tenantId])
}

model BarberUnit {
  id        String @id @default(cuid())
  barberId  String
  barber    Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)
  unitId    String
  unit      Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  schedule  Json

  @@unique([barberId, unitId])
}

model BarberBlock {
  id        String   @id @default(cuid())
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  reason    String?
}

// Jornada semanal do profissional por unidade. Varias linhas no mesmo dia =
// turno quebrado (ex.: 09-12 e 14-19). Dia sem linha = nao trabalha. dayOfWeek
// segue Date.getDay() (0=domingo) e horario em minutos — sem chave de idioma,
// mata o bug PT/EN na raiz. Substitui o BarberUnit.schedule (Json, dado morto).
model WorkShift {
  id        String @id @default(cuid())
  barberId  String
  barber    Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)
  unitId    String
  unit      Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0=domingo .. 6=sabado (Date.getDay)
  startMin  Int // minutos desde 00:00 (540 = 09:00)
  endMin    Int // minutos desde 00:00 (1140 = 19:00)

  @@index([barberId, unitId, dayOfWeek])
}

// Indisponibilidade por periodo: o profissional nao atende naquelas datas.
// Termo geral de proposito (sem taxonomia de motivo). allDay=false -> so uma
// faixa de horario do dia. unitId null = vale em todas as unidades.
model Unavailability {
  id        String   @id @default(cuid())
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  unitId    String?
  unit      Unit?    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  startDate DateTime // dia inclusivo (00:00 local)
  endDate   DateTime // dia inclusivo (00:00 local)
  allDay    Boolean  @default(true)
  startMin  Int? // se allDay=false: inicio da faixa indisponivel
  endMin    Int? // se allDay=false: fim
  reason    String? // opcional, livre
  createdAt DateTime @default(now())

  @@index([barberId, startDate, endDate])
}

model Client {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  email       String?
  totalVisits Int       @default(0)
  lastVisit   DateTime?
  createdAt   DateTime  @default(now())

  bookings Booking[]

  @@unique([tenantId, phone])
}

model Booking {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId      String?
  unit        Unit?         @relation(fields: [unitId], references: [id])
  barberId    String
  barber      Barber        @relation(fields: [barberId], references: [id])
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id])
  dateTime    DateTime
  durationMin Int
  price       Float
  status      BookingStatus @default(CONFIRMED)
  origin      BookingOrigin @default(APP)
  campaignRef String?
  // pagamento (PIX via Asaas). status do dinheiro e separado do status da agenda.
  paymentStatus  PaymentStatus @default(NONE)
  paymentMode    PaymentMode?
  asaasPaymentId String?       @unique
  pixCopiaECola  String?
  chargeAmount   Float?        // valor do PIX (ja com desconto); fonte da verdade p/ paidAmount
  paidAmount     Float?
  pixExpiresAt   DateTime?
  // lembrete de 1 dia antes ja disparado ao cliente (cron /api/cron/reminders).
  // null = ainda nao enviado; guarda contra disparo duplicado.
  reminderSentAt DateTime?
  // pedido: servico + produtos (order bumps). itensTotal = soma dos produtos;
  // orderTotal = total do pedido (servico + produtos), o "hall do que foi adquirido".
  itemsTotal  Float         @default(0)
  orderTotal  Float?
  items       BookingItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId, dateTime])
  @@index([barberId, dateTime])
}

// Linha do pedido: o que foi adquirido no agendamento (servico + produtos).
// name/unitPrice sao SNAPSHOT do momento da compra (preco do catalogo pode mudar).
model BookingItem {
  id        String          @id @default(cuid())
  bookingId String
  booking   Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  kind      BookingItemKind
  refId     String // serviceId ou productId de origem
  name      String
  unitPrice Float
  quantity  Int             @default(1)
  productId String?
  product   Product?        @relation(fields: [productId], references: [id])
  createdAt DateTime        @default(now())

  @@index([bookingId])
}

enum BookingItemKind {
  SERVICE
  PRODUCT
  UPSELL_SERVICE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED_CLIENT
  CANCELLED_BARBER
  NO_SHOW
}

enum BookingOrigin {
  APP
  WHATSAPP
  WALK_IN
  PHONE
  INSTAGRAM
}

enum PaymentStatus {
  NONE    // sem pagamento (agendamento de balcao/whatsapp)
  PENDING // PIX gerado, aguardando
  PAID    // pagamento caiu
  EXPIRED // PIX nao pago dentro da janela
}

enum PaymentMode {
  SINAL // 50 por cento, restante no balcao
  TOTAL // 100 por cento
}

enum BookingMode {
  PAYMENT_REQUIRED // so agenda pagando (sinal ou total)
  PAYMENT_OPTIONAL // pode pagar adiantado OU so agendar
  BOOK_ONLY        // so agenda, sem cobranca
}